# ===========================================
# PaaS Web Frontend - Environment Variables
# ===========================================

# API Configuration
# -----------------
# Server-only base URL for backend API (used for internal auth sync).
API_BASE_URL=http://localhost:8080

# Public base URL for browser-side requests.
# Keep this value safe to expose in client bundles.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Set to "true" to use mock API responses instead of real backend
NEXT_PUBLIC_USE_MOCK_API=true

# OAuth Configuration
# -------------------
# NextAuth secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl

# NextAuth URL - your frontend URL
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Internal auth sync
# ------------------
# Must match INTERNAL_AUTH_SYNC_SECRET used by the API process.
INTERNAL_AUTH_SYNC_SECRET=replace-with-a-strong-internal-sync-secret

# BFF to API JWT
# --------------
# Must match BFF_JWT_SECRET used by the API process for /v0 bearer verification.
BFF_JWT_SECRET=replace-with-a-strong-shared-secret

# Optional overrides for API JWT claims minted by web auth callback.
BFF_JWT_ISSUER=spacescale-web-bff
BFF_JWT_AUDIENCE=spacescale-api
BFF_JWT_TTL_SECONDS=3600

# Optional dedicated secret to hash JWT sub values into opaque identifiers.
# If omitted, NEXTAUTH_SECRET (then BFF_JWT_SECRET) is used.
BFF_SUBJECT_HASH_SECRET=replace-with-a-strong-subject-hash-secret

# Refresh token settings for API access-token rotation.
# In production, BFF_REFRESH_TOKEN_SECRET must be explicitly configured.
BFF_REFRESH_TOKEN_SECRET=replace-with-a-strong-refresh-secret
BFF_REFRESH_TOKEN_AUDIENCE=spacescale-api-refresh
BFF_REFRESH_TOKEN_TTL_SECONDS=2592000

# Platform Configuration
# ----------------------
# Your platform's domain for app subdomains
NEXT_PUBLIC_PLATFORM_DOMAIN=ourplatform.io
