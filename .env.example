# Docker compose host port bindings
API_PORT=8080
DB_PORT=5432

# Postgres container settings
POSTGRES_USER=spacescale
POSTGRES_PASSWORD=spacescale
POSTGRES_DB=postgres
PGDATA=/var/lib/postgresql/18/docker

# API runtime settings (inside docker network)
ADDR=:8080
DATABASE_URL=postgres://spacescale:spacescale@db:5432/spacescale?sslmode=disable
# API per-user rate limiting
# Allows 100 requests per authenticated user in a 1 minute window.
API_USER_RATE_LIMIT_REQUESTS=100
API_USER_RATE_LIMIT_WINDOW=1m

# API log privacy settings for user-agent fields.
# Modes: hash, truncate, off.
API_LOG_USER_AGENT_MODE=hash
# Use a dedicated secret for HMAC hashing. Do NOT reuse BFF_JWT_SECRET.
API_LOG_USER_AGENT_HASH_SECRET=replace-with-a-separate-hmac-secret
# Applied only when mode is "truncate".
API_LOG_USER_AGENT_MAX_LEN=100
# Panic log redaction and stack trace policy.
# Panic values are truncated to this many characters.
API_LOG_PANIC_VALUE_MAX_LEN=200
# Set true in local debugging; false is safer for production logs.
API_LOG_STACK_TRACE=false

# BFF-issued JWT verification settings used by API
BFF_JWT_SECRET=replace-with-a-strong-shared-secret
BFF_JWT_ISSUER=spacescale-web-bff
BFF_JWT_AUDIENCE=spacescale-api
BFF_JWT_SUB=github:t0gun
