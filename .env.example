# Local Docker DB host port (used by Makefile workflows)
DB_PORT=5432

# Postgres container settings
POSTGRES_USER=spacescale
POSTGRES_PASSWORD=spacescale
POSTGRES_DB=postgres
PGDATA=/var/lib/postgresql/18/docker

# API runtime settings (native API + local Dockerized Postgres)
ADDR=:8080
DATABASE_URL=postgres://spacescale:spacescale@localhost:5432/spacescale?sslmode=disable
TEST_DATABASE_URL=postgres://spacescale:spacescale@localhost:5432/spacescale_test?sslmode=disable
# API per-user rate limiting
# Allows 100 requests per authenticated user in a 1 minute window.
API_USER_RATE_LIMIT_REQUESTS=100
API_USER_RATE_LIMIT_WINDOW=1m
# Internal auth-sync global circuit breaker (high threshold)
API_INTERNAL_GLOBAL_RATE_LIMIT_REQUESTS=12000
API_INTERNAL_GLOBAL_RATE_LIMIT_WINDOW=1m
# Internal auth-sync per-identity guardrail
API_INTERNAL_IDENTITY_RATE_LIMIT_REQUESTS=30
API_INTERNAL_IDENTITY_RATE_LIMIT_WINDOW=1m

# API log privacy settings for user-agent fields.
# Modes: hash, truncate, off.
API_LOG_USER_AGENT_MODE=hash
# Use a dedicated secret for HMAC hashing. Do NOT reuse BFF_JWT_SECRET.
API_LOG_USER_AGENT_HASH_SECRET=replace-with-a-separate-hmac-secret
# Applied only when mode is "truncate".
API_LOG_USER_AGENT_MAX_LEN=100
# Panic log redaction and stack trace policy.
# Panic values are truncated to this many characters.
API_LOG_PANIC_VALUE_MAX_LEN=200
# Set true in local debugging; false is safer for production logs.
API_LOG_STACK_TRACE=false

# BFF-issued JWT verification settings used by API.
# The web app must use the same BFF_JWT_SECRET when minting API bearer tokens.
BFF_JWT_SECRET=replace-with-a-strong-shared-secret
BFF_JWT_ISSUER=spacescale-web-bff
BFF_JWT_AUDIENCE=spacescale-api
# Identity key used by `make mint` to issue local API tokens.
# Examples: email:you@example.com or github:12345
BFF_IDENTITY_KEY=email:you@example.com
# Shared secret used by web auth callback to call API internal auth-sync route.
INTERNAL_AUTH_SYNC_SECRET=replace-with-a-strong-internal-sync-secret

# App env var encryption settings (AES-256-GCM).
# API_ENV_ENCRYPTION_KEY must be base64-encoded 32-byte key material.
# Example generation: openssl rand -base64 32
API_ENV_ENCRYPTION_KEY_ID=local-v1
API_ENV_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
# Optional decrypt-only keys for rotation windows.
# Format: comma-separated key_id:base64 pairs.
API_ENV_ENCRYPTION_DECRYPT_KEYS=
# Optional env re-encryption worker tuning.
# Batch size controls rows claimed per transaction.
API_ENV_ENCRYPTION_REENCRYPT_BATCH_SIZE=100
# Sweep period controls how often the background worker runs.
API_ENV_ENCRYPTION_REENCRYPT_SWEEP_PERIOD=30s

# Control-plane server settings (API process)
# TCP listen address for control-plane stream server.
CONTROL_PLANE_ADDR=:9090
# Shared bearer token required from all scaled agents.
CONTROL_PLANE_AGENT_TOKEN=replace-with-a-strong-control-plane-agent-token
# Expected heartbeat cadence returned to agents at registration.
CONTROL_PLANE_HEARTBEAT_INTERVAL=10s
# Offline cutoff window when heartbeats are missed.
CONTROL_PLANE_LEASE_TTL=45s
# Throttled interval for persisting agent last_seen_at to Postgres.
CONTROL_PLANE_AGENT_LAST_SEEN_FLUSH_INTERVAL=30s
# Max inbound gRPC message size in bytes.
CONTROL_PLANE_MAX_RECV_MSG_BYTES=1048576
# Max outbound gRPC message size in bytes.
CONTROL_PLANE_MAX_SEND_MSG_BYTES=1048576

# Scaled agent settings
# Control-plane address the agent dials.
SCALED_CONTROL_PLANE_ADDR=127.0.0.1:9090
# Stable unique agent identity key used across reconnects.
SCALED_AGENT_KEY=replace-with-a-stable-agent-key
# Optional: when empty, scaled computes a display name from hostname + key hash.
SCALED_AGENT_NAME=
# Optional: when empty, scaled uses build metadata or "unknown".
SCALED_AGENT_VERSION=
# Caller label included in RPC request metadata for tracing.
SCALED_CALLER=scaled/startup
# Agent status sent in heartbeat payloads.
SCALED_STATUS=ready
# Comma-separated capability IDs advertised at registration.
SCALED_CAPABILITIES=firecracker,logs,heartbeat
# Timeout for initial control-plane dial.
SCALED_GRPC_DIAL_TIMEOUT=10s
# Timeout for unary Health RPC call.
SCALED_GRPC_HEALTH_TIMEOUT=5s
# Minimum per-attempt connect timeout used by gRPC.
SCALED_GRPC_MIN_CONNECT_TIMEOUT=5s
# First retry delay after a transient disconnect.
SCALED_RECONNECT_INITIAL_BACKOFF=1s
# Max retry delay cap for exponential reconnect backoff.
SCALED_RECONNECT_MAX_BACKOFF=30s
# Fallback heartbeat interval if server response omits/invalidates cadence.
SCALED_HEARTBEAT_FALLBACK_INTERVAL=10s
